# Cloud Run GPU (NVIDIA L4) / GCE GPU 용 이미지.
# Qwen3-14B QLoRA(4bit) 추론에는 CUDA 가 필수.
#
# ⚠️ CUDA 버전 주의: Cloud Run L4 인스턴스의 드라이버는 CUDA 12.2(12020) 수준.
#    torch 가 더 높은 CUDA(예: 12.4)로 컴파일돼 있으면 "driver too old" 로 GPU
#    초기화에 실패한다. 따라서 베이스는 12.1.1, torch 는 cu121 휠로 고정한다.
#    (cu121 휠은 드라이버 12.2 와 호환)
# ⚠️ transformers 4.55+ 는 torch.distributed.tensor.device_mesh (torch 2.5+) 를
#    요구하므로 torch 2.5.1 사용.
#
# CPU 전용 배포는 루트의 Dockerfile 을 사용하세요.
FROM nvidia/cuda:12.1.1-cudnn8-runtime-ubuntu22.04

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1 \
    PORT=8080 \
    DEBIAN_FRONTEND=noninteractive \
    HF_HOME=/app/.hf_cache

WORKDIR /app

# Python + xgboost 런타임 의존(libgomp1). Ubuntu 22.04 기본 Python 3.10.
RUN apt-get update && apt-get install -y --no-install-recommends \
    python3 python3-pip python3-venv libgomp1 \
    && ln -sf /usr/bin/python3 /usr/bin/python \
    && rm -rf /var/lib/apt/lists/*

# torch 를 cu121 휠(2.5.1)로 먼저 설치 — 드라이버 12.2 호환 + transformers 4.55+ 요구 충족.
RUN python -m pip install --upgrade pip \
    && python -m pip install torch==2.5.1 --index-url https://download.pytorch.org/whl/cu121

# 1) 웹/표 모델 의존 (gdown, google-auth 포함)
COPY requirements.txt .
RUN python -m pip install -r requirements.txt

# 2) LLM 추론 의존 (GPU). transformers (Qwen3), bitsandbytes(4bit) 등.
#    torch 는 위에서 cu121 로 설치됐으므로 재설치되지 않는다.
COPY src/training/requirements_llm.txt ./requirements_llm.txt
RUN python -m pip install -r requirements_llm.txt

# 2.5) 베이스 모델(Qwen3-14B, ~28GB)을 이미지에 굽는다 — 런타임 HF 429 근본 차단.
#     HF_HOME=/app/.hf_cache 와 동일 경로에 받아야 런타임이 재다운로드하지 않는다.
#     xet 비활성으로 안정적인 LFS 경로 사용. (BAKE_MODEL=1 일 때만 실행)
ARG BAKE_MODEL=0
ENV HF_HUB_DISABLE_XET=1 HF_HUB_ENABLE_HF_TRANSFER=0
RUN if [ "$BAKE_MODEL" = "1" ]; then \
      python -c "from huggingface_hub import snapshot_download; \
        snapshot_download('Qwen/Qwen3-14B', \
          allow_patterns=['*.json','*.txt','*.safetensors','merges.txt','tokenizer*'])" \
      && echo 'baked Qwen3-14B into image'; \
    else echo 'skip baking (BAKE_MODEL=0) — base model pulled at runtime'; fi

# Source + trained artifacts
COPY src ./src
COPY frontend ./frontend
COPY artifacts ./artifacts
COPY deploy/entrypoint.sh ./deploy/entrypoint.sh
RUN chmod +x ./deploy/entrypoint.sh

EXPOSE 8080

# 시작 시 GPU 진단 → (LLM 켜진 경우) Drive 어댑터 백그라운드 다운로드 → 서버 기동.
CMD ["sh", "./deploy/entrypoint.sh"]
